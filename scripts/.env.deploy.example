# Deploy Secret — FinAgent Workspace
# Copia este archivo como .env.deploy y reemplaza con el secret real:
#   cp scripts/.env.deploy.example scripts/.env.deploy
#
# El secret lo obtienes al ejecutar vps-setup.sh en el VPS.
# Nunca hagas commit de .env.deploy (ya está en .gitignore).

DEPLOY_SECRET=REEMPLAZAR_CON_SECRET_DEL_VPS
